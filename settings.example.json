{
    "providers": {
        "finnhub": {
            "api_key": "your_finnhub_api_key",
            "timeout": 5,
            "enabled": true
        }
    },
    "scheduler": {
        "interval_minutes": 5,
        "historical": {
            "enabled": false,
            "resolution": "D",
            "lookback_days": 30
        }
    },
    "results_dir": "stock_bot/results",
    "tradingagents": {
        "path": "/path/to/TradingAgents",
        "results_path": "/path/to/TradingAgents/eval_results",
        "default_analysts": ["market", "social", "news", "fundamentals"],
        "default_depth": 2,
        "default_llm": "minimax"
    }
}
